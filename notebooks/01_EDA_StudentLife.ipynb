    "## 6. Temporal Analysis <a id='temporal'></a>"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Function to analyze temporal coverage\n",
    "def analyze_temporal_coverage(directory):\n",
    "    \"\"\"Analyze the temporal coverage of the dataset\"\"\"\n",
    "    user_data = {}\n",
    "    \n",
    "    # Get all user directories\n",
    "    user_dirs = [d for d in directory.iterdir() if d.is_dir() and str(d.name).startswith('u')]\n",
    "    \n",
    "    for user_dir in user_dirs[:5]:  # Analyze first 5 users\n",
    "        user_id = user_dir.name\n",
    "        user_data[user_id] = {}\n",
    "        \n",
    "        # Check each data type\n",
    "        for data_type in ['gps', 'accel', 'wifi', 'bluetooth', 'conversation', 'ema']:\n",
    "            data_dir = user_dir / data_type\n",
    "            if data_dir.exists():\n",
    "                files = list(data_dir.glob('*.csv'))\n",
    "                if files:\n",
    "                    # Extract dates from filenames\n",
    "                    dates = []\n",
    "                    for file in files:\n",
    "                        filename = file.name\n",
    "                        if '_' in filename:\n",
    "                            date_part = filename.split('_')[-1].split('.')[0]\n",
    "                            if date_part.isdigit():\n",
    "                                dates.append(int(date_part))\n",
    "                    \n",
    "                    if dates:\n",
    "                        user_data[user_id][data_type] = {\n",
    "                            'file_count': len(files),\n",
    "                            'date_range': (min(dates), max(dates)),\n",
    "                            'coverage_days': len(set(dates))\n",
    "                        }\n",
    "    \n",
    "    return user_data\n",
    "\n",
    "# Analyze temporal coverage\n",
    "if DATA_DIR.exists():\n",
    "    coverage = analyze_temporal_coverage(DATA_DIR)\n",
    "    print("📅 Temporal Coverage Analysis:")\n",
    "    for user_id, data_types in coverage.items():\n",
    "        print(f"\\nUser {user_id}:")\n",
    "        for data_type, info in data_types.items():\n",
    "            print(f"  {data_type}: {info['file_count']} files, {info['coverage_days']} days, range: {info['date_range']}")"
   ]
  },
