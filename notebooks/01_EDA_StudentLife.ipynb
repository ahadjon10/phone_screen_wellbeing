    "%matplotlib inline\n",
    "\n",
    "# Configuration\n",
    "DATA_DIR = Path('../data/raw')\n",
    "PROCESSED_DIR = Path('../data/processed')\n",
    "EXTERNAL_DIR = Path('../data/external')\n",
    "\n",
    "# Create directories if they don't exist\n",
    "PROCESSED_DIR.mkdir(parents=True, exist_ok=True)"
