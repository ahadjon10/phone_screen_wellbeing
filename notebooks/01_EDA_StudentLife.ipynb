    "## 5. Sensor Data Exploration <a id='sensors'></a>"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Function to load and analyze specific sensor data\n",
    "def analyze_gps_data(directory, user_id='u001', limit_days=5):\n",
    "    \"\"\"Analyze GPS data for a specific user\"\"\"\n",
    "    gps_dir = directory / 'gps' / user_id\n",
    "    \n",
    "    if not gps_dir.exists():\n",
    "        print(f"❌ GPS directory not found for user {user_id}")\n",
    "        return None\n",
    "    \n",
    "    # Load all GPS files for this user\n",
    "    gps_files = sorted(gps_dir.glob('*.csv'))[:limit_days]\n",
    "    \n",
    "    if not gps_files:\n",
    "        print(f"❌ No GPS files found for user {user_id}")\n",
    "        return None\n",
    "    \n",
    "    print(f"📍 Loading GPS data for user {user_id}")\n",
    "    print(f"Found {len(gps_files)} GPS files")\n",
    "    \n",
    "    # Load first file to understand structure\n",
    "    sample_file = gps_files[0]\n",
    "    df = pd.read_csv(sample_file)\n",
    "    print(f"GPS file structure: {df.shape}")\n",
    "    print(f"Columns: {list(df.columns)}")\n",
    "    \n",
    "    # Try to parse timestamps and calculate basic statistics\n",
    "    if 'timestamp' in df.columns:\n",
    "        df['timestamp'] = pd.to_datetime(df['timestamp'], unit='ms')\n",
    "        print(f"Time range: {df['timestamp'].min()} to {df['timestamp'].max()}")\n",
    "    \n",
    "    if 'latitude' in df.columns and 'longitude' in df.columns:\n",
    "        print(f"Latitude range: {df['latitude'].min():.6f} to {df['latitude'].max():.6f}")\n",
    "        print(f"Longitude range: {df['longitude'].min():.6f} to {df['longitude'].max():.6f}")\n",
    "        print(f"Accuracy range: {df['accuracy'].min():.1f} to {df['accuracy'].max():.1f}")\n",
    "    \n",
    "    return df\n",
    "\n",
    "# Analyze GPS data for first user\n",
    "if DATA_DIR.exists():\n",
    "    gps_df = analyze_gps_data(DATA_DIR, 'u001')\n",
    "    if gps_df is not None:\n",
    "        display(gps_df.head())"
   ]
  },
