   "cell_type": "markdown",
   "source": [
    "## 4. File Structure Analysis <a id='structure'></a>"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Function to analyze file sizes and completeness\n",
    "def analyze_file_properties(directory):\n",
    "    \"\"\"Analyze file sizes and data completeness\"\"\"\n",
    "    file_info = []\n",
    "    \n",
    "    csv_files = list(directory.rglob('*.csv'))\n",
    "    \n",
    "    for file_path in csv_files:\n",
    "        try:\n",
    "            # Get file size\n",
    "            file_size = file_path.stat().st_size / 1024  # KB\n",
    "            \n",
    "            # Extract metadata from path\n",
    "            parts = str(file_path).split(os.sep)\n",
    "            user_id = [p for p in parts if p.startswith('u') and len(p) == 4 and p[1:].isdigit()][0] if any(p.startswith('u') and len(p) == 4 and p[1:].isdigit() for p in parts) else 'unknown'\n",
    "            data_type = file_path.parent.name\n",
    "            filename = file_path.name\n",
    "            \n",
    "            # Try to get row count\n",
    "            try:\n",
    "                df = pd.read_csv(file_path)\n",
    "                row_count = len(df)\n",
    "                col_count = len(df.columns)\n",
    "            except:\n",
    "                row_count = 0\n",
    "                col_count = 0\n",
    "            \n",
    "            file_info.append({\n",
    "                'user_id': user_id,\n",
    "                'data_type': data_type,\n",
    "                'filename': filename,\n",
    "                'file_size_kb': file_size,\n",
    "                'row_count': row_count,\n",
    "                'col_count': col_count,\n",
    "                'file_path': str(file_path.relative_to(directory))\n",
    "            })\n",
    "        except Exception as e:\n",
    "            print(f"Error processing {file_path}: {e}")\n",
    "    \n",
    "    return pd.DataFrame(file_info)\n",
    "\n",
    "# Analyze file properties (this may take a while for large datasets)\n",
    "if DATA_DIR.exists():\n",
    "    print("Analyzing file properties...")\n",
    "    file_df = analyze_file_properties(DATA_DIR)\n",
    "    print(f"Analyzed {len(file_df)} files")\n",
    "    \n",
    "    # Show summary statistics\n",
    "    print("\\n📊 File Statistics Summary:")\n",
    "    print(file_df.groupby('data_type').agg({\n",
    "        'file_size_kb': ['mean', 'min', 'max'],\n",
    "        'row_count': ['mean', 'min', 'max'],\n",
    "        'filename': 'count'\n",
    "    }))\n",
    "    \n",
    "    # Show largest files\n",
    "    print("\\n📈 Largest files by data type:")\n",
    "    for data_type in file_df['data_type'].unique():\n",
    "        type_files = file_df[file_df['data_type'] == data_type]\n",
    "        if not type_files.empty:\n",
    "            largest = type_files.nlargest(3, 'file_size_kb')\n",
    "            print(f"\\n{data_type}:")\n",
    "            for _, row in largest.iterrows():\n",
    "                print(f"  {row['filename']}: {row['file_size_kb']:.1f} KB, {row['row_count']} rows")"
   ]
  },
