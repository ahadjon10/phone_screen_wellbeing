  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Function to analyze dataset structure\n",
    "def analyze_dataset_structure(directory):\n",
    "    \"\"\"Analyze the structure of the StudentLife dataset\"\"\"\n",
    "    stats = {\n",
    "        'total_files': 0,\n",
    "        'user_ids': set(),\n",
    "        'data_types': {},\n",
    "        'date_ranges': {}\n",
    "    }\n",
    "    \n",
    "    # Find all CSV files\n",
    "    csv_files = list(directory.rglob('*.csv'))\n",
    "    stats['total_files'] = len(csv_files)\n",
    "    \n",
    "    for file_path in csv_files:\n",
    "        # Extract user ID from path\n",
    "        parts = str(file_path).split(os.sep)\n",
    "        user_dirs = [p for p in parts if p.startswith('u') and len(p) == 4 and p[1:].isdigit()]\n",
    "        if user_dirs:\n",
    "            stats['user_ids'].add(user_dirs[0])\n",
    "        \n",
    "        # Extract data type (parent directory name)\n",
    "        data_type = file_path.parent.name\n",
    "        if data_type not in stats['data_types']:\n",
    "            stats['data_types'][data_type] = 0\n",
    "        stats['data_types'][data_type] += 1\n",
    "        \n",
    "        # Extract date from filename\n",
    "        filename = file_path.name\n",
    "        if '_' in filename:\n",
    "            date_part = filename.split('_')[-1].split('.')[0]\n",
    "            if date_part.isdigit():\n",
    "                if data_type not in stats['date_ranges']:\n",
    "                    stats['date_ranges'][data_type] = []\n",
    "                stats['date_ranges'][data_type].append(int(date_part))\n",
    "    \n",
    "    # Process date ranges\n",
    "    for data_type, dates in stats['date_ranges'].items():\n",
    "        if dates:\n",
    "            stats['date_ranges'][data_type] = (min(dates), max(dates), len(dates))\n",
    "    \n",
    "    return stats\n",
    "\n",
    "# Analyze the dataset\n",
    "if DATA_DIR.exists():\n",
    "    stats = analyze_dataset_structure(DATA_DIR)\n",
    "    print("📊 Dataset Statistics:")\n",
    "    print(f"Total CSV files: {stats['total_files']}")\n",
    "    print(f"Number of participants: {len(stats['user_ids'])}")\n",
    "    print(f"Participant IDs: {sorted(stats['user_ids'])}")\n",
    "    print(f"\\nData types found:")\n",
    "    for data_type, count in stats['data_types'].items():\n",
    "        print(f"  - {data_type}: {count} files")\n",
    "    print(f"\\nDate ranges:")\n",
    "    for data_type, (min_date, max_date, count) in stats['date_ranges'].items():\n",
    "        print(f"  - {data_type}: {min_date} to {max_date} ({count} days)")"
   ]
  },
  {
   "cell_type": "markdown",
   "source": [
    "## 3. Dataset Overview <a id='overview'></a>"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Function to load and preview sample data from each sensor type\n",
    "def preview_sensor_data(directory, sample_size=3):\n",
    "    \"\"\"Load and preview sample data from different sensor types\"\"\"\n",
    "    sensor_types = ['gps', 'accel', 'wifi', 'bluetooth', 'conversation', 'app', 'screen', 'ema']\n",
    "    \n",
    "    for sensor_type in sensor_types:\n",
    "        sensor_dir = directory / sensor_type\n",
    "        if sensor_dir.exists():\n",
    "            print(f"\\n🔍 {sensor_type.upper()} Data:")\n",
    "            user_dirs = [d for d in sensor_dir.iterdir() if d.is_dir()]\n",
    "            if user_dirs:\n",
    "                sample_user = user_dirs[0]\n",
    "                files = list(sample_user.glob('*.csv'))\n",
    "                if files:\n",
    "                    sample_file = files[0]\n",
    "                    try:\n",
    "                        df = pd.read_csv(sample_file, nrows=sample_size)\n",
    "                        print(f"Sample file: {sample_file.relative_to(directory)}")\n",
    "                        print(f"Shape: {df.shape}")\n",
    "                        print(f"Columns: {list(df.columns)}")\n",
    "                        display(df.head(sample_size))\n",
    "                    except Exception as e:\n",
    "                        print(f"Error loading {sample_file}: {e}")\n",
    "            else:\n",
    "                print(f"No user directories found in {sensor_type}")\n",
    "        else:\n",
    "            print(f"❌ {sensor_type} directory not found")\n",
    "\n",
    "if DATA_DIR.exists():\n",
    "    preview_sensor_data(DATA_DIR)"
   ]
  },
