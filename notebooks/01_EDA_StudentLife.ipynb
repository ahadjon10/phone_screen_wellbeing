   "source": [
    "# Function to analyze data completeness per participant\n",
    "def analyze_participant_completeness(directory):\n",
    "    \"\"\"Analyze how complete the data is for each participant\"\"\"\n",
    "    completeness = []\n",
    "    \n",
    "    # Expected data types\n",
    "    expected_types = ['gps', 'accel', 'wifi', 'bluetooth', 'conversation', 'app', 'screen', 'ema']\n",
    "    \n",
    "    # Get all user directories\n",
    "    user_dirs = [d for d in directory.iterdir() if d.is_dir() and str(d.name).startswith('u')]\n",
    "    \n",
    "    for user_dir in user_dirs:\n",
    "        user_id = user_dir.name\n",
    "        user_completeness = {'user_id': user_id}\n",
    "        \n",
    "        for data_type in expected_types:\n",
    "            data_dir = user_dir / data_type\n",
    "            if data_dir.exists():\n",
    "                files = list(data_dir.glob('*.csv'))\n",
    "                user_completeness[data_type] = len(files)\n",
    "            else:\n",
    "                user_completeness[data_type] = 0\n",
    "        \n",
    "        completeness.append(user_completeness)\n",
    "    \n",
    "    return pd.DataFrame(completeness)\n",
    "\n",
    "# Analyze participant completeness\n",
    "if DATA_DIR.exists():\n",
    "    completeness_df = analyze_participant_completeness(DATA_DIR)\n",
    "    print("👥 Participant Data Completeness:")\n",
    "    display(completeness_df.describe())\n",
    "    \n",
    "    # Show which participants have the most complete data\n",
    "    completeness_df['total_files'] = completeness_df[expected_types].sum(axis=1)\n",
    "    top_participants = completeness_df.nlargest(10, 'total_files')\n",
    "    print("\\n🏆 Top 10 participants by data completeness:")\n",
    "    display(top_participants[['user_id'] + expected_types + ['total_files']])"
   ]
