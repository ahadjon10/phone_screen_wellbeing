    "# Function to analyze accelerometer data\n",
    "def analyze_accel_data(directory, user_id='u001', limit_days=3):\n",
    "    \"\"\"Analyze accelerometer data for a specific user\"\"\"\n",
    "    accel_dir = directory / 'accel' / user_id\n",
    "    \n",
    "    if not accel_dir.exists():\n",
    "        print(f"❌ Accelerometer directory not found for user {user_id}")\n",
    "        return None\n",
    "    \n",
    "    accel_files = sorted(accel_dir.glob('*.csv'))[:limit_days]\n",
    "    \n",
    "    if not accel_files:\n",
    "        print(f"❌ No accelerometer files found for user {user_id}")\n",
    "        return None\n",
    "    \n",
    "    print(f"📱 Loading accelerometer data for user {user_id}")\n",
    "    print(f"Found {len(accel_files)} accelerometer files")\n",
    "    \n",
    "    # Load first file\n",
    "    sample_file = accel_files[0]\n",
    "    df = pd.read_csv(sample_file)\n",
    "    print(f"Accelerometer file structure: {df.shape}")\n",
    "    print(f"Columns: {list(df.columns)}")\n",
    "    \n",
    "    # Calculate basic statistics\n",
    "    if 'timestamp' in df.columns:\n",
    "        df['timestamp'] = pd.to_datetime(df['timestamp'], unit='ms')\n",
    "        print(f"Time range: {df['timestamp'].min()} to {df['timestamp'].max()}")\n",
    "    \n",
    "    # Calculate magnitude if x, y, z columns exist\n",
    "    accel_cols = ['x', 'y', 'z']\n",
    "    if all(col in df.columns for col in accel_cols):\n",
    "        df['magnitude'] = np.sqrt(df['x']**2 + df['y']**2 + df['z']**2)\n",
    "        print(f"Magnitude range: {df['magnitude'].min():.3f} to {df['magnitude'].max():.3f}")\n",
    "        print(f"Mean magnitude: {df['magnitude'].mean():.3f}")\n",
    "    \n",
    "    return df\n",
    "\n",
    "# Analyze accelerometer data\n",
    "if DATA_DIR.exists():\n",
    "    accel_df = analyze_accel_data(DATA_DIR, 'u001')\n",
    "    if accel_df is not None:\n",
    "        display(accel_df.head())"
   ]
